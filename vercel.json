{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/regulamin", "destination": "/regulamin.html" },
    {
      "source": "/polityka-prywatnosci",
      "destination": "/polityka-prywatnosci.html"
    }
  ],
  "cleanUrls": true
}
